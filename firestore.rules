rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Deny all reads and writes by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Users can only read and write their own data
    match /users/{userId}/{collection}/{docId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId
                         && isValidCollection(collection)
                         && isValidPayload(request.resource.data);
    }
  }
}

// Only allow the four known data collections
function isValidCollection(collection) {
  return collection == 'categories'
      || collection == 'articles'
      || collection == 'outfits'
      || collection == 'collections';
}

// Basic payload validation: must have a 'data' field and a 'userId' string
function isValidPayload(data) {
  return data.keys().hasAll(['data', 'userId'])
      && data.userId is string
      && data.userId.size() > 0;
}
